<actionGroups xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="urn:magento:mftf:Test/etc/actionGroupSchema.xsd">

    <actionGroup name="StorefrontProductReviewCreationActionGroup">

        <amOnPage url="{{ProductUrl3.value}}.html"
                  stepKey="navigateToRequiredPDP1"/>
        <click selector="{{StorefrontPDPReviewElementsSection.ReviewsTab}}"
               stepKey="clickOnReviewsTab1"/>
        <click selector="{{StorefrontPDPReviewElementsSection.RatingStar('1')}}"
               stepKey="clickOnRatingStar1"/>
        <fillField userInput="Test Nickname1"
                   selector="{{StorefrontPDPReviewElementsSection.ReviewDataField('nickname')}}"
                   stepKey="fillNicknameField1"/>
        <fillField userInput="Test Summary1"
                   selector="{{StorefrontPDPReviewElementsSection.ReviewDataField('summary')}}"
                   stepKey="fillSummaryField1"/>
        <fillField userInput="Test Review1"
                   selector="{{StorefrontPDPReviewElementsSection.ReviewDataField('review')}}"
                   stepKey="fillReviewField1"/>
        <click selector="{{StorefrontPDPReviewElementsSection.SubmitButton('Submit Review')}}"
               stepKey="clickOnSubmitReviewButton1"/>

        <amOnPage url="{{ProductUrl3.value}}.html"
                  stepKey="navigateToRequiredPDP2"/>
